{
  "name": "rgs-remotion-render-worker",
  "version": "0.1.0",
  "private": true,
  "description": "RGS external Remotion render worker. Polls campaign-video-render-claim, renders MP4 via Remotion, uploads to private bucket, calls campaign-video-render-callback. Not deployed inside Lovable.",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}